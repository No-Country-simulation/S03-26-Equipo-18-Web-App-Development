{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "rootDir": "./src",
        "outDir": "./dist",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "types": ["node", "express", "multer", "cors", "dotenv", "helmet"]
    },
    "include": ["src/**/*"]
}