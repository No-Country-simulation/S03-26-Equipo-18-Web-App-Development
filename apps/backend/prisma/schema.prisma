generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Testimonio {
  id        Int      @id @default(autoincrement())
  nombre    String
  mensaje   String
  estado    String   @default("PENDIENTE")
  createdAt DateTime @default(now())
}