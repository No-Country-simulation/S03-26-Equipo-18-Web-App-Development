datasource db {
  provider = "sqlite" // Aquí cambias a "mysql" o "sqlite" si usas otro
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(cuid())
  username     String
  email        String   @unique
  password     String
  role         String   @default("ADMIN") // 'ADMIN', 'EDITOR', etc.
  active       Boolean  @default(true)
  apiKey       String?   @unique @default(uuid()) // La llave para su API
  instituto    String  // El nombre de la institución (ex EdTech.name)
  createdAt    DateTime @default(now())
  testimonials Testimonial[]
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  testimonials Testimonial[]
}

model Tag{
  id        String   @id @default(cuid())
  name      String   @unique
  testimonials Testimonial[]
}

model Testimonial {
  id          String   @id @default(cuid())
  userName    String   // Nombre del usuario
  content     String   // El texto del testimonio
  rating      Int      @default(5) // Estrellas
  location    String   @default("")
  //Valores: 'PENDING', 'APPROVED', 'REJECTED'
  status      String   @default("PENDIENTE")
  instituto   String
  videoUrl    String?
  //proveedor de video("YOUTUBE","CLOUDINARY","NONE")
  videoProvider String @default("NONE")
  createdAt   DateTime @default(now()) 
  
  // Conexión con la EdTech
  user          User?     @relation(fields: [userId], references: [id])
  userId        String?

  // RELACIÓN CON CATEGORY (Uno a Muchos)
  category      Category @relation(fields: [categoryId], references: [id])
  categoryId    String

  // RELACIÓN CON TAGS (Muchos a Muchos)
  tags          Tag[]
}