datasource db {
  provider = "sqlite" // Aquí cambias a "mysql" o "sqlite" si usas otro
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(cuid())
  username     String
  email        String   @unique
  password     String
  role         String   @default("ADMIN") // 'ADMIN', 'EDITOR', etc.
  
    //El ID del ADMIN principal al que pertenece este usuario
    //Si este user es el ADMIN principal, este campo estará vacío(null)
  adminId      String?  
    //La relación técnica para que Prisma entienda la jerarquía
  admin        User?    @relation("UserOwnership", fields: [adminId], references: [id])
    //Lista de usuarios que este ADMIN principal tiene a su cargo
  staff        User[]   @relation("UserOwnership") 
  active       Boolean  @default(true)
  apiKey       String?   @unique @default(uuid()) // La llave para su API
  organization String  // El nombre de la institución (ex EdTech.name)
  createdAt    DateTime @default(now())
  testimonials Testimonial[]
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  testimonials Testimonial[]
}

model Tag{
  id        String   @id @default(cuid())
  name      String   @unique
  testimonials Testimonial[]
}

model Testimonial {
  id          String   @id @default(cuid())
  userName    String   // Nombre del usuario
  content     String   // El texto del testimonio
  rating      Int      @default(0) // Estrellas
  location    String   @default("")
  status      String   @default("PENDIENTE")
  videoUrl    String?
  //proveedor de video("YOUTUBE","CLOUDINARY","NONE")
  videoProvider String @default("NONE")
  createdAt   DateTime @default(now()) 
  views       Int     @default(0)
  clicks      Int     @default(0)
  
  // Conexión con la EdTech
  user          User?     @relation(fields: [userId], references: [id])
  userId        String?   //Aquí SIEMPRE el ID del ADMIN principal

  // RELACIÓN CON CATEGORY (Uno a Muchos)
  category      Category @relation(fields: [categoryId], references: [id])
  categoryId    String

  // RELACIÓN CON TAGS (Muchos a Muchos)
  tags          Tag[]
}